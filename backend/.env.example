PORT=3001

# S3 Configuration (Hitachi or S3-compatible storage)
S3_ENDPOINT=https://your-hitachi-endpoint.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=kulkas-images
S3_REGION=us-east-1
# S3_PUBLIC_URL is optional - if not set, will use S3_ENDPOINT
# S3_PUBLIC_URL=https://your-public-url.com

